# Copy this file to .env and fill in your values
# Never commit .env to git

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenWeatherMap (free tier)
EXPO_PUBLIC_OPENWEATHER_API_KEY=your-openweathermap-api-key

# PhotoRoom (sandbox = free, watermarked — swap for production key when ready)
EXPO_PUBLIC_PHOTOROOM_API_KEY=your-photoroom-api-key

# Claude API (Anthropic)
EXPO_PUBLIC_CLAUDE_API_KEY=your-claude-api-key
