# Copy this file to .env and fill in your own values.
# NEVER commit .env — it is git-ignored.

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenWeatherMap (free tier — https://openweathermap.org/api)
EXPO_PUBLIC_OPENWEATHER_API_KEY=your_openweathermap_api_key

# PhotoRoom background removal (sandbox = free + watermarked)
EXPO_PUBLIC_PHOTOROOM_API_KEY=sandbox_sk_pr_your_key

# Claude AI — claude-sonnet-4-6 (outfit suggestions + clothing tagging)
EXPO_PUBLIC_CLAUDE_API_KEY=sk-ant-api03-your_key
